+static bool amdgpu_dm_dp_path_supports_freesync(struct drm_dp_aux *aux)
+{
+	u8 dpcd[DP_RECEIVER_CAP_SIZE];
+
+	if (drm_dp_read_dpcd_caps(aux, dpcd) < 0)
+		return false;
+
+	return drm_dp_sink_can_do_video_without_timing_msa(dpcd);
+}
+
+/* MST VRR requires every receiver in the path to tolerate invalid MSA timing. */
+static bool
+amdgpu_dm_mst_path_supports_freesync(struct amdgpu_dm_connector *aconnector)
+{
+	struct drm_dp_mst_port *port = aconnector->mst_output_port;
+	struct drm_dp_mst_branch *mstb;
+
+	if (!port || !port->mgr || !port->mgr->aux)
+		return false;
+
+	if (!amdgpu_dm_dp_path_supports_freesync(&port->aux))
+		return false;
+
+	for (mstb = port->parent; mstb; ) {
+		struct drm_dp_aux *aux;
+
+		if (mstb->port_parent) {
+			aux = &mstb->port_parent->aux;
+			mstb = mstb->port_parent->parent;
+		} else {
+			aux = port->mgr->aux;
+			mstb = NULL;
+		}
+
+		if (!amdgpu_dm_dp_path_supports_freesync(aux))
+			return false;
+	}
+
+	return true;
+}
